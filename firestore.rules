rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // User tự đọc doc của mình HOẶC admin (check qua custom claim, không tốn
      // extra Firestore read như get()). Claim được sync từ users/{uid}.admin
      // qua Cloud Function syncAdminClaim. Admin mới grant phải refresh token
      // (logout/login hoặc đợi 1h) trước khi đọc được docs khác.
      allow read: if request.auth != null
                  && (
                    request.auth.uid == userId
                    || request.auth.token.admin == true
                  );

      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasOnly(['email', 'premium', 'admin', 'expiredAt', 'createdAt'])
                    && request.resource.data.email == request.auth.token.email
                    && request.resource.data.premium == false
                    && request.resource.data.admin == false
                    && request.resource.data.createdAt == request.time;

      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
