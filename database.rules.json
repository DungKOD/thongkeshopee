{
  "rules": {
    "status": {
      ".read": "auth != null && auth.token.admin === true",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "user_device_limits": {
      ".read": "auth != null && auth.token.admin === true",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.admin === true)",
        ".write": "auth != null && auth.token.admin === true",
        ".validate": "newData.isNumber() && newData.val() >= 1 && newData.val() <= 99"
      }
    },
    "user_devices": {
      ".read": "auth != null && auth.token.admin === true",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.admin === true)",
        "$fingerprint": {
          ".write": "auth != null && (auth.token.admin === true || (auth.uid === $uid && newData.exists() && (data.exists() || root.child('user_devices').child($uid).numChildren() < (root.child('user_device_limits').child($uid).val() != null ? root.child('user_device_limits').child($uid).val() : 1))))",
          ".validate": "newData.hasChildren(['hostname', 'os', 'createdAt', 'lastSeen'])"
        }
      }
    }
  }
}
